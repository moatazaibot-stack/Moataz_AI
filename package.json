{
  "name": "moataz-ai",
  "version": "1.0.0",
  "description": "Moataz AI — Enterprise AI Operating System",
  "private": true,
  "author": "Moataz AI Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
