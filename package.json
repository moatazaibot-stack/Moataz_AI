  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production node .next/standalone/server.js",
    "lint": "eslint .",
    "test": "bun test --passWithNoTests",
    "test:security": "bun test tests/prompt-injection.test.ts",
    "test:failover": "bun test tests/smart-router-failover.test.ts",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next node_modules/.cache"
  },
